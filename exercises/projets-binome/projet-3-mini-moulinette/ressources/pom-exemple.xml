<?xml version="1.0" encoding="UTF-8"?>
<!--
  POM D'EXEMPLE pour le Projet binôme #3 — à ADAPTER (groupId, artifactId, nom de package).

  Il fournit ce dont vous avez besoin pour la partie « tests » du projet :
    - JUnit 5 + AssertJ pour écrire vos tests ;
    - JaCoCo pour MESURER la couverture (exigence : >= 70 %).

  Commandes utiles :
    mvn test                      # compile + lance les tests
    mvn test                      # génère aussi le rapport JaCoCo (lié à la phase test ci-dessous)
    -> ouvrez ensuite  target/site/jacoco/index.html  pour voir le pourcentage de couverture.

  Vérifié : JaCoCo 0.8.13 fonctionne avec le JDK 25 de la Piscine.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- À ADAPTER à votre binôme -->
    <groupId>etnc.binome</groupId>
    <artifactId>mini-moulinette</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>25</maven.compiler.release>
        <junit.version>5.11.0</junit.version>
        <assertj.version>3.26.3</assertj.version>
        <jacoco.version>0.8.13</jacoco.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.0</version>
            </plugin>

            <!-- JaCoCo : mesure de la couverture des tests -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <executions>
                    <!-- 1. instrumente le code avant les tests -->
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <!-- 2. génère le rapport HTML après les tests (cible : target/site/jacoco/) -->
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <!-- 3. (optionnel) échoue le build si la couverture passe sous 70 % :
                         décommentez ce bloc pour transformer l'exigence en garde-fou automatique.
                    <execution>
                        <id>check</id>
                        <phase>test</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.70</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                    -->
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
