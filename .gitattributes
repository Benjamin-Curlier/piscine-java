# Normalisation des fins de ligne — évite les surprises CRLF/LF entre Windows et Linux.
# Par défaut : Git décide (text=auto), normalise en LF dans le dépôt.
* text=auto

# Scripts shell : TOUJOURS en LF, sinon ils plantent sur Linux/macOS
# (notamment les lanceurs piscine.sh et build-bundle.sh / piscine-bootstrap.sh).
*.sh    text eol=lf

# Scripts Windows : CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Sources et docs : LF dans le dépôt (cohérent multi-plateforme)
*.java  text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.json  text eol=lf

# Binaires : jamais de conversion
*.jar   binary
*.zip   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.pdf   binary
