{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files)",
      "Bash(git ls-files:*)",
      "Bash(gh repo view)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view)",
      "Bash(gh issue view:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
